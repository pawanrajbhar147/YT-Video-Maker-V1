# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Generated media and output data
audio/*
images/*
output/*
working/*

# Keep folder structure visible in Git
!audio/.gitkeep
!images/.gitkeep
!output/.gitkeep
!output/logs/.gitkeep
!output/Upload/.gitkeep
!working/.gitkeep
